# Server configuration
PORT=3000
NODE_ENV=development # production, development, test

# Blockchain configuration
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your_private_key_here

# Contract addresses
SWAP_CREATOR_ADAPTER_ADDRESS=0x14Ab64a2f29f4921c200280988eea59c85266A33
SWAP_CREATOR_ADDRESS=0x07b9c8BF96E553Adec406cC6ab8c41CCD3d53a51

# API configuration
API_KEY=your_api_key_here
ONEINCH_API_KEY=your_1inch_api_key_here

# SwapD configuration
SWAPD_RPC_URL=http://127.0.0.1:5000

# Lit Protocol configuration
LIT_NETWORK=serrano # serrano, cayenne, jalapeno, etc.
LIT_DEBUG=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # 100 requests per minute
