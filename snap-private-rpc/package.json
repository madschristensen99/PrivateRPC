{
  "name": "private-rpc-snap",
  "version": "0.1.0",
  "description": "MetaMask Snap for PrivateRPC providing enhanced privacy features and atomic ETH ↔ XMR swaps",
  "repository": {
    "type": "git",
    "url": "https://github.com/madschristensen99/PrivateRPC.git"
  },
  "license": "MIT",
  "main": "dist/bundle.js",
  "files": [
    "dist/",
    "images/",
    "snap.manifest.json"
  ],
  "scripts": {
    "build": "mm-snap build",
    "build:clean": "yarn clean && yarn build",
    "clean": "rimraf dist",
    "lint": "yarn lint:eslint && yarn lint:misc --check",
    "lint:eslint": "eslint . --cache --ext js,ts",
    "lint:fix": "yarn lint:eslint --fix && yarn lint:misc --write",
    "lint:misc": "prettier '**/*.json' '**/*.md' '!CHANGELOG.md' --ignore-path .gitignore",
    "serve": "mm-snap serve",
    "start": "mm-snap watch",
    "test": "jest"
  },
  "dependencies": {
    "@metamask/key-tree": "^7.0.0",
    "@metamask/snaps-types": "^0.32.2",
    "@metamask/snaps-ui": "^0.32.2",
    "buffer": "^6.0.3",
    "ethers": "^5.7.2"
  },
  "devDependencies": {
    "@metamask/auto-changelog": "^3.1.0",
    "@metamask/eslint-config": "^12.0.0",
    "@metamask/eslint-config-jest": "^12.0.0",
    "@metamask/eslint-config-nodejs": "^12.0.0",
    "@metamask/eslint-config-typescript": "^12.0.0",
    "@metamask/snaps-cli": "^0.32.2",
    "@types/jest": "^29.5.1",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-jsdoc": "^46.2.6",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "prettier-plugin-packagejson": "^2.4.3",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
